@model IEnumerable<Watchly.Web.Models.ViewModels.MovieCardViewModel>
@{ ViewData["Title"] = "Избранное"; }

<div class="catalog-header">
    <h2><i class="fas fa-heart"></i> Моё избранное</h2>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-heart fa-3x mb-3"></i>
        <p>Список избранного пуст. Добавляйте фильмы, нажимая на иконку сердца.</p>
        <a asp-controller="Cinema" asp-action="Index" class="btn-primary mt-3">
            <i class="fas fa-th"></i> Перейти в каталог
        </a>
    </div>
}
else
{
    <div class="movie-grid">
        @foreach (var movie in Model)
        {
            <article class="movie-card movie-card-rich">
                <a asp-action="Detail" asp-route-id="@movie.Id" class="movie-card-link">
                    <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? "https://via.placeholder.com/250x360?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h3 class="movie-card-title">@movie.Title</h3>
                        <div class="movie-card-meta">
                            <span class="movie-year">@movie.ReleaseYear</span>
                            <span class="movie-rating"><i class="fas fa-star"></i> @movie.Rating</span>
                        </div>
                        <p class="movie-genres">@string.Join(", ", movie.Genres)</p>
                    </div>
                </a>
                <form asp-controller="Cinema" asp-action="ToggleWatchlist" method="post" class="card-watchlist-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="movieId" value="@movie.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn-watchlist in-watchlist" title="Убрать из избранного">
                        <i class="fas fa-heart"></i>
                    </button>
                </form>
            </article>
        }
    </div>
}
