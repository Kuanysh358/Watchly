@model IEnumerable<Watchly.Web.Models.ViewModels.MovieCardViewModel>
@{ ViewData["Title"] = "История просмотров"; }
<h2>История просмотров</h2>
<div class="movie-grid">@foreach (var movie in Model){<article class="movie-card"><h3>@movie.Title</h3><p>@movie.ReleaseYear • ⭐ @movie.Rating</p><a class="btn-secondary" asp-action="Detail" asp-route-id="@movie.Id">Открыть</a></article>}</div>
