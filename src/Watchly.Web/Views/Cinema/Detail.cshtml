@model Watchly.Web.Models.ViewModels.MovieDetailViewModel
@{ ViewData["Title"] = Model.Title; }

@{
    var hasMoviePlayer = !string.IsNullOrWhiteSpace(Model.VideoUrl) || Model.TmdbId.HasValue;
    var hasTrailer = !string.IsNullOrWhiteSpace(Model.TrailerUrl);
    var initialMode = hasMoviePlayer ? "movie" : (hasTrailer ? "trailer" : "none");
}

<section class="cinema-detail-page" id="cinemaDetailPage">
    <div class="detail-backdrop" style="background-image: linear-gradient(120deg, rgba(10,7,20,.85), rgba(27,14,45,.9)), url('@(string.IsNullOrWhiteSpace(Model.BackdropUrl) ? Model.PosterUrl : Model.BackdropUrl)');"></div>

    <div class="detail-shell">
        <header class="detail-hero-v2">
            <div class="detail-poster-wrap">
                <img class="detail-poster" src="@(string.IsNullOrWhiteSpace(Model.PosterUrl) ? "https://via.placeholder.com/300x450?text=No+Poster" : Model.PosterUrl)" alt="@Model.Title" />
            </div>

            <div class="detail-main">
                <div class="detail-kicker">Смотреть онлайн</div>
                <h1 class="detail-title">@Model.Title <span class="detail-year">(@Model.ReleaseYear)</span></h1>

                <div class="detail-info-row">
                    <span class="badge-rating"><i class="fas fa-star"></i> @Model.Rating</span>
                    <span class="detail-genres">@string.Join(" • ", Model.Genres)</span>
                </div>

                <div class="detail-info-row text-muted small">
                    @if (!string.IsNullOrWhiteSpace(Model.Director)) { <span><strong>Режиссёр:</strong> @Model.Director</span> }
                    @if (!string.IsNullOrWhiteSpace(Model.Country)) { <span><strong>Страна:</strong> @Model.Country</span> }
                    @if (Model.DurationMinutes.HasValue) { <span><strong>Длительность:</strong> @Model.DurationMinutes мин.</span> }
                </div>

                <p class="detail-description">@Model.Description</p>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="detail-actions mt-3">
                        <button type="button" id="showMovieBtn" class="btn-primary" @(hasMoviePlayer ? null : "disabled")><i class="fas fa-play"></i> Смотреть фильм</button>
                        <button type="button" id="showTrailerBtn" class="btn-secondary" @(hasTrailer ? null : "disabled")><i class="fas fa-video"></i> Трейлер</button>
                        <form asp-action="ToggleWatchlist" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="movieId" value="@Model.Id" />
                            <button type="submit" class="@(Model.IsInWatchlist ? "btn-danger" : "btn-primary")">
                                <i class="fas @(Model.IsInWatchlist ? "fa-heart-broken" : "fa-heart")"></i>
                                @(Model.IsInWatchlist ? "Убрать из избранного" : "В избранное")
                            </button>
                        </form>
                        <button type="button" id="copyMovieLinkBtn" class="btn-secondary"><i class="fas fa-link"></i> Копировать ссылку</button>
                        <button type="button" class="btn-secondary" data-bs-toggle="modal" data-bs-target="#shareMovieModal"><i class="fas fa-paper-plane"></i> Отправить другу</button>
                    </div>
                }
            </div>
        </header>

        <section id="playerSection" class="player-section mb-4" data-initial-mode="@initialMode" data-movie-url="@Model.VideoUrl" data-fallback-url="@(Model.TmdbId.HasValue ? $"https://vidsrc.to/embed/movie/{Model.TmdbId.Value}" : "")" data-trailer-url="@Model.TrailerUrl">
            <h3 class="section-title"><i class="fas fa-play-circle"></i> Плеер</h3>
            <div id="moviePlayerBlock" class="video-player-wrap @(initialMode == "movie" ? string.Empty : "d-none")">
                <div class="trailer-player-wrap">
                    <iframe id="moviePlayerFrame" class="trailer-player" src="@(initialMode == "movie" ? Model.VideoUrl : "")" allowfullscreen allow="autoplay; fullscreen" sandbox="allow-forms allow-scripts allow-same-origin allow-popups allow-presentation" referrerpolicy="origin"></iframe>
                </div>
            </div>
            <div id="trailerPlayerBlock" class="video-player-wrap @(initialMode == "trailer" ? string.Empty : "d-none")">
                <div class="trailer-player-wrap">
                    <iframe id="trailerFrame" class="trailer-player" src="" allowfullscreen allow="autoplay; encrypted-media; fullscreen" referrerpolicy="origin"></iframe>
                </div>
            </div>
            @if (!hasMoviePlayer && !hasTrailer)
            {
                <div id="emptyPlayerBlock" class="detail-panel text-center py-4">
                    <i class="fas fa-film fa-3x mb-3 text-muted"></i>
                    <p class="text-muted">Видео недоступно для этого фильма.</p>
                </div>
            }
        </section>
    </div>
</section>

@if (User.Identity?.IsAuthenticated == true)
{
    <section class="mb-4 detail-panel">
        <h3 class="section-title"><i class="fas fa-star-half-alt"></i> Ваша оценка</h3>
        <form asp-action="SetRating" method="post" class="rating-form modern-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="movieId" value="@Model.Id" />
            <div class="rating-stars" id="ratingStars">
                @for (int i = 1; i <= 10; i++)
                {
                    <button type="button" class="star-btn @(Model.UserRating >= i ? "active" : "")" data-value="@i">@i</button>
                }
            </div>
            <input type="hidden" name="score" id="ratingScore" value="@(Model.UserRating == 0 ? 8 : Model.UserRating)" />
            <button class="btn-primary mt-2 action-wide" type="submit"><i class="fas fa-check"></i> Сохранить оценку</button>
        </form>
    </section>

    <section class="mb-4 detail-panel">
        <div class="d-flex justify-content-between align-items-center mb-3 comments-head">
            <h3 class="section-title mb-0"><i class="fas fa-comments"></i> Комментарии (@Model.Comments.Count)</h3>
            <div class="comment-sort">
                <a asp-action="Detail" asp-route-id="@Model.Id" asp-route-commentSort="newest"
                   class="btn-secondary btn-sm @(ViewBag.CommentSort == "newest" ? "active" : "")">Новые</a>
                <a asp-action="Detail" asp-route-id="@Model.Id" asp-route-commentSort="popular"
                   class="btn-secondary btn-sm @(ViewBag.CommentSort == "popular" ? "active" : "")">Популярные</a>
            </div>
        </div>
        <form asp-action="AddComment" method="post" class="mb-4 modern-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="movieId" value="@Model.Id" />
            <textarea name="text" class="form-control comment-input" rows="3" required placeholder="Ваш отзыв о фильме..."></textarea>
            <button class="btn-primary mt-2 action-wide" type="submit"><i class="fas fa-paper-plane"></i> Оставить комментарий</button>
        </form>

        <div class="comments-list">
            @foreach (var comment in Model.Comments)
            {
                <article class="comment-card">
                    <div class="comment-header">
                        <strong class="comment-author">@comment.UserName</strong>
                        <small class="comment-date text-muted">@comment.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                    <p class="comment-text">@comment.Text</p>
                    <div class="comment-actions">
                        <button type="button" class="btn-like @(comment.LikedByCurrentUser ? "liked" : "")" data-comment-id="@comment.Id" onclick="toggleLike(this, @comment.Id)">
                            <i class="fas fa-thumbs-up"></i> @comment.LikeCount
                        </button>
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-action="DeleteComment" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="commentId" value="@comment.Id" />
                                <input type="hidden" name="movieId" value="@Model.Id" />
                                <button type="submit" class="btn-danger btn-sm" onclick="return confirm('Удалить комментарий?')"><i class="fas fa-trash"></i></button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    </section>
}


<div class="modal fade" id="shareMovieModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title">Отправить фильм другу</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Profile" asp-action="SendMessage" method="post">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="movieId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">Кому отправить</label>
                        <select class="form-select" name="friendId" required>
                            <option value="">Выберите друга</option>
                            @foreach (var friend in Model.ShareFriends)
                            {
                                <option value="@friend.UserId">@(string.IsNullOrWhiteSpace(friend.FullName) ? friend.UserName : $"{friend.FullName} (@{friend.UserName})")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Сообщение</label>
                        <textarea class="form-control" name="text" rows="3" placeholder="Комментарий к фильму"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-secondary" type="button" data-bs-dismiss="modal">Отмена</button>
                    <button class="btn-primary" type="submit">Отправить</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const section = document.getElementById('playerSection');
    if (!section) return;

    const normalizeTrailerUrl = (url) => {
        if (!url) return '';
        try {
            const parsed = new URL(url, window.location.origin);
            if (parsed.hostname.includes('youtube.com') && parsed.searchParams.get('v')) {
                return `https://www.youtube.com/embed/${parsed.searchParams.get('v')}?autoplay=1`;
            }
            if (parsed.hostname.includes('youtu.be')) {
                const id = parsed.pathname.replace('/', '').trim();
                return id ? `https://www.youtube.com/embed/${id}?autoplay=1` : url;
            }
            return url;
        } catch {
            return url;
        }
    };

    const showMovieBtn = document.getElementById('showMovieBtn');
    const showTrailerBtn = document.getElementById('showTrailerBtn');
    const movieBlock = document.getElementById('moviePlayerBlock');
    const trailerBlock = document.getElementById('trailerPlayerBlock');
    const movieFrame = document.getElementById('moviePlayerFrame');
    const trailerFrame = document.getElementById('trailerFrame');
    const primaryMovieUrl = section.dataset.movieUrl || '';
    const fallbackMovieUrl = section.dataset.fallbackUrl || '';
    const trailerUrl = normalizeTrailerUrl(section.dataset.trailerUrl || '');
    let fallbackApplied = false;

    const switchMode = (mode) => {
        if (movieBlock) movieBlock.classList.toggle('d-none', mode !== 'movie');
        if (trailerBlock) trailerBlock.classList.toggle('d-none', mode !== 'trailer');
        if (mode === 'movie' && movieFrame && !movieFrame.src) {
            movieFrame.src = primaryMovieUrl || fallbackMovieUrl;
        }
        if (mode === 'trailer' && trailerFrame && trailerUrl) trailerFrame.src = trailerUrl;
    };

    if (movieFrame) {
        movieFrame.addEventListener('error', () => {
            if (!fallbackApplied && fallbackMovieUrl) {
                fallbackApplied = true;
                movieFrame.src = fallbackMovieUrl;
            }
        });
    }

    if (showMovieBtn) showMovieBtn.addEventListener('click', () => switchMode('movie'));
    if (showTrailerBtn) showTrailerBtn.addEventListener('click', () => switchMode('trailer'));
    switchMode(section.dataset.initialMode || 'none');
})();

(() => {
    const copyBtn = document.getElementById('copyMovieLinkBtn');
    if (!copyBtn) return;
    const originalHtml = copyBtn.innerHTML;
    copyBtn.addEventListener('click', async () => {
        const url = window.location.href;
        try {
            if (navigator.clipboard) {
                await navigator.clipboard.writeText(url);
                copyBtn.textContent = 'Ссылка скопирована';
                setTimeout(() => { copyBtn.innerHTML = originalHtml; }, 2000);
            } else {
                window.prompt('Скопируйте ссылку', url);
            }
        } catch {
            window.prompt('Скопируйте ссылку', url);
        }
    });
})();
</script>
}
