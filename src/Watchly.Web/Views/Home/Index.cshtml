@model Watchly.Web.Models.ViewModels.HomeIndexViewModel
@{ ViewData["Title"] = "Главная"; }

<section class="showcase-hero mb-5">
    <div class="showcase-main">
        @{ var featured = Model.Popular.FirstOrDefault() ?? Model.NewReleases.FirstOrDefault(); }
        @if (featured != null)
        {
            <img class="showcase-backdrop" src="@(string.IsNullOrWhiteSpace(featured.PosterUrl) ? "https://via.placeholder.com/1200x520?text=Watchly" : featured.PosterUrl)" alt="@featured.Title" />
            <div class="showcase-overlay"></div>
            <div class="showcase-content">
                <span class="showcase-chip">Премьера недели</span>
                <h1>@featured.Title</h1>
                <p>Собрали для вас топовые фильмы и сериалы в стиле современного онлайн-кинотеатра.</p>
                <div class="showcase-actions">
                    <a class="btn-primary btn-lg" asp-controller="Cinema" asp-action="Detail" asp-route-id="@featured.Id">
                        <i class="fas fa-play"></i> Смотреть
                    </a>
                    <a class="btn-secondary btn-lg" asp-controller="Cinema" asp-action="Detail" asp-route-id="@featured.Id">
                        <i class="fas fa-circle-info"></i> Подробнее
                    </a>
                </div>
            </div>
        }
    </div>
</section>

<section class="category-row mb-5">
    <a class="category-pill" asp-controller="Cinema" asp-action="Index"><i class="fas fa-clapperboard"></i> Фильмы</a>
    <a class="category-pill" asp-controller="Cinema" asp-action="Index"><i class="fas fa-tv"></i> Сериалы</a>
    <a class="category-pill" asp-controller="Cinema" asp-action="Index"><i class="fas fa-bolt"></i> Экшен</a>
    <a class="category-pill" asp-controller="Cinema" asp-action="Index"><i class="fas fa-heart"></i> Драма</a>
    <a class="category-pill" asp-controller="Cinema" asp-action="Index"><i class="fas fa-dragon"></i> Фэнтези</a>
</section>

<section class="mb-5">
    <div class="section-header"><h3><i class="fas fa-fire"></i> Популярные</h3></div>
    <div class="movie-grid">
        @foreach (var movie in Model.Popular)
        {
            <article class="movie-card movie-card-rich">
                <a asp-controller="Cinema" asp-action="Detail" asp-route-id="@movie.Id" class="movie-card-link">
                    <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? "https://via.placeholder.com/250x360?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h4 class="movie-card-title">@movie.Title</h4>
                        <div class="movie-card-meta"><span class="movie-year">@movie.ReleaseYear</span><span class="movie-rating"><i class="fas fa-star"></i> @movie.Rating</span></div>
                        <p class="movie-genres">@string.Join(", ", movie.Genres)</p>
                    </div>
                </a>
            </article>
        }
    </div>
</section>

<section class="mb-5">
    <div class="section-header"><h3><i class="fas fa-calendar-alt"></i> Новые релизы</h3></div>
    <div class="movie-grid">
        @foreach (var movie in Model.NewReleases)
        {
            <article class="movie-card movie-card-rich">
                <a asp-controller="Cinema" asp-action="Detail" asp-route-id="@movie.Id" class="movie-card-link">
                    <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? "https://via.placeholder.com/250x360?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h4 class="movie-card-title">@movie.Title</h4>
                        <div class="movie-card-meta"><span class="movie-year">@movie.ReleaseYear</span><span class="movie-rating"><i class="fas fa-star"></i> @movie.Rating</span></div>
                        <p class="movie-genres">@string.Join(", ", movie.Genres)</p>
                    </div>
                </a>
            </article>
        }
    </div>
</section>

<section class="hero-catalog-cta text-center py-5">
    <a class="btn-primary btn-lg" asp-controller="Cinema" asp-action="Index"><i class="fas fa-th"></i> Открыть полный каталог</a>
</section>
