@model Watchly.Web.Models.ViewModels.HomeIndexViewModel
@{ ViewData["Title"] = "Главная"; }

<section class="hero">
    <h1>Watchly</h1>
    <p>Тёмный онлайн-кинотеатр: популярные, новые и подборки по жанрам.</p>
</section>

<section class="mb-5">
    <div class="section-header">
        <h3><i class="fas fa-fire"></i> Популярные</h3>
    </div>
    <div class="movie-grid">
        @foreach (var movie in Model.Popular)
        {
            <article class="movie-card">
                <a asp-controller="Cinema" asp-action="Detail" asp-route-id="@movie.Id" class="movie-card-link">
                    <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? "https://via.placeholder.com/250x360?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h4>@movie.Title</h4>
                        <span class="movie-year">@movie.ReleaseYear</span>
                        <span class="movie-rating"><i class="fas fa-star"></i> @movie.Rating</span>
                    </div>
                </a>
            </article>
        }
    </div>
</section>

<section class="mb-5">
    <div class="section-header">
        <h3><i class="fas fa-calendar-alt"></i> Новые релизы</h3>
    </div>
    <div class="movie-grid">
        @foreach (var movie in Model.NewReleases)
        {
            <article class="movie-card">
                <a asp-controller="Cinema" asp-action="Detail" asp-route-id="@movie.Id" class="movie-card-link">
                    <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? "https://via.placeholder.com/250x360?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h4>@movie.Title</h4>
                        <span class="movie-year">@movie.ReleaseYear</span>
                        <p class="movie-genres">@string.Join(", ", movie.Genres)</p>
                    </div>
                </a>
            </article>
        }
    </div>
</section>

@foreach (var genreSection in Model.ByGenres)
{
    <section class="mb-5">
        <div class="section-header">
            <h3><i class="fas fa-film"></i> @genreSection.Key</h3>
        </div>
        <div class="movie-grid">
            @foreach (var movie in genreSection.Value)
            {
                <article class="movie-card">
                    <a asp-controller="Cinema" asp-action="Detail" asp-route-id="@movie.Id" class="movie-card-link">
                        <img src="@(string.IsNullOrWhiteSpace(movie.PosterUrl) ? "https://via.placeholder.com/250x360?text=No+Poster" : movie.PosterUrl)" alt="@movie.Title" />
                        <div class="movie-card-info">
                            <h4>@movie.Title</h4>
                            <span class="movie-year">@movie.ReleaseYear</span>
                        </div>
                    </a>
                </article>
            }
        </div>
    </section>
}

<section class="hero-catalog-cta text-center py-5">
    <a class="btn-primary btn-lg" asp-controller="Cinema" asp-action="Index">
        <i class="fas fa-th"></i> Открыть полный каталог
    </a>
</section>
