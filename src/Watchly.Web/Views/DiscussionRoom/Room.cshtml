@model Watchly.Web.Models.ViewModels.DiscussionRoomViewModel
@{ ViewData["Title"] = "Талқылау бөлмесі"; }

<div class="chat-shell">
    <div class="chat-header">
        <a class="btn-secondary btn-sm" asp-controller="Cinema" asp-action="Detail" asp-route-id="@Model.MovieId">Фильмге өту</a>
        <div class="chat-user">
            @if (!string.IsNullOrWhiteSpace(Model.FriendAvatarUrl))
            {
                <img src="@Model.FriendAvatarUrl" alt="Аватар" class="friend-avatar" />
            }
            <div>
                <div class="friend-name">@Model.FriendName</div>
                <div class="text-muted small">Бөлме: @Model.MovieTitle</div>
            </div>
        </div>
    </div>

    @if (Model.IsPending)
    {
        <div class="alert alert-warning">Шақыру жіберілді. Досыңыз қосылғаннан кейін чат ашылады.</div>
        @if (!Model.IsInitiator)
        {
            <form asp-action="Join" method="post" class="mb-3">@Html.AntiForgeryToken()<input type="hidden" name="roomId" value="@Model.RoomId" /><button class="btn-primary" type="submit">Бөлмеге қосылу</button></form>
        }
    }

    @if (Model.IsActive)
    {
        <form asp-action="Close" method="post" class="mb-2">@Html.AntiForgeryToken()<input type="hidden" name="roomId" value="@Model.RoomId" /><button class="btn-danger btn-sm" type="submit">Бөлмені жабу</button></form>
    }

    @if (Model.IsClosed)
    {
        <div class="alert alert-secondary">Бұл бөлме жабық.</div>
    }

    <div class="chat-messages">
        @foreach (var message in Model.Messages)
        {
            <div class="chat-message @(message.IsOwn ? "own" : "other")"><div class="chat-bubble">@if (!string.IsNullOrWhiteSpace(message.Text)){<p>@message.Text</p>}<span class="chat-time">@message.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span></div></div>
        }
    </div>

    @if (Model.IsActive)
    {
        <form class="chat-input" asp-action="SendMessage" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="roomId" value="@Model.RoomId" />
            <input class="form-control" name="text" placeholder="Хабарлама..." autocomplete="off" />
            <input type="file" class="form-control" name="image" accept="image/*" />
            <button class="btn-primary" type="submit">Жіберу</button>
        </form>
    }
</div>
