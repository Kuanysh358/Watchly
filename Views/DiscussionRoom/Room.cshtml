@model Watchly.Web.Models.ViewModels.DiscussionRoomViewModel
@using System.Globalization
@{
    ViewData["Title"] = Model.MovieTitle + " — " + (CultureInfo.CurrentUICulture.TwoLetterISOLanguageName is "kk" or "kz" ? "Талқылау бөлмесі" : "Комната обсуждения");
    var isKz = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName is "kk" or "kz";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
}

<div class="room-page">
    <!-- Video Player Section -->
    <div class="room-player-section">
        @if (!string.IsNullOrWhiteSpace(Model.MovieVideoUrl))
        {
            @if (Model.MovieVideoIsIframe)
            {
                <div class="room-video-wrap">
                    <iframe class="room-video-iframe" src="@Model.MovieVideoUrl"
                            allowfullscreen referrerpolicy="origin"
                            allow="autoplay; fullscreen; picture-in-picture"></iframe>
                </div>
            }
            else
            {
                <div class="room-video-wrap">
                    <video id="roomPlayer" controls style="width:100%;height:100%;background:#000;">
                        <source src="@Model.MovieVideoUrl" />
                    </video>
                </div>
            }
        }
        else
        {
            <div class="room-video-placeholder">
                @if (!string.IsNullOrWhiteSpace(Model.MoviePosterUrl))
                {
                    <img src="@Model.MoviePosterUrl" alt="@Model.MovieTitle" class="room-poster-fallback" />
                }
                <div class="room-no-video-msg">
                    <i class="fas fa-film fa-3x mb-3"></i>
                    <p>@(isKz ? "Бейне қолжетімді емес" : "Видео недоступно")</p>
                </div>
            </div>
        }
        <div class="room-player-footer">
            <div class="room-movie-info">
                @if (!string.IsNullOrWhiteSpace(Model.MoviePosterUrl))
                {
                    <img src="@Model.MoviePosterUrl" alt="@Model.MovieTitle" class="room-mini-poster" />
                }
                <div>
                    <div class="room-movie-title">@Model.MovieTitle</div>
                    <a class="room-movie-link" asp-controller="Cinema" asp-action="Detail" asp-route-id="@Model.MovieId">
                        <i class="fas fa-info-circle"></i> @(isKz ? "Фильм туралы" : "О фильме")
                    </a>
                </div>
            </div>
            <div class="room-controls">
                @if (Model.IsClosed)
                {
                    <span class="room-status-badge closed">@(isKz ? "Жабық" : "Закрыта")</span>
                }
                else if (Model.IsActive)
                {
                    <span class="room-status-badge active">@(isKz ? "Белсенді" : "Активна")</span>
                    <form asp-action="Close" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="roomId" value="@Model.RoomId" />
                        <button class="btn-danger btn-sm" type="submit" onclick="return confirm('@(isKz ? "Бөлмені жабасыз ба?" : "Закрыть комнату?")')">
                            <i class="fas fa-door-closed"></i> @(isKz ? "Бөлмені жабу" : "Закрыть комнату")
                        </button>
                    </form>
                }
                else if (Model.IsPending)
                {
                    <span class="room-status-badge pending">@(isKz ? "Күтуде" : "Ожидание")</span>
                }
            </div>
        </div>
    </div>

    <!-- Chat Section -->
    <div class="room-chat-section">
        <div class="chat-shell room-chat-shell">
            <div class="chat-header">
                <div class="chat-user">
                    @if (!string.IsNullOrWhiteSpace(Model.FriendAvatarUrl))
                    {
                        <img src="@Model.FriendAvatarUrl" alt="@Model.FriendName" class="friend-avatar" />
                    }
                    else
                    {
                        <div class="friend-avatar-placeholder"><i class="fas fa-user"></i></div>
                    }
                    <div>
                        <div class="friend-name">@Model.FriendName</div>
                        <div class="text-muted small">
                            @if (Model.IsActive) { <span class="dot-online"></span> } @(isKz ? "Бөлме чаты" : "Чат комнаты")
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.IsPending && !Model.IsInitiator)
            {
                <div class="alert alert-info mb-2">
                    <i class="fas fa-bell"></i>
                    @(isKz ? "Сізді бөлмеге шақырды. Қосылу?" : "Вас пригласили в комнату. Присоединиться?")
                    <div class="mt-2 d-flex gap-2">
                        <form asp-action="Join" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roomId" value="@Model.RoomId" />
                            <button class="btn-primary btn-sm" type="submit">
                                <i class="fas fa-sign-in-alt"></i> @(isKz ? "Қосылу" : "Присоединиться")
                            </button>
                        </form>
                        <a asp-controller="Cinema" asp-action="Detail" asp-route-id="@Model.MovieId" class="btn-secondary btn-sm">
                            <i class="fas fa-times"></i> @(isKz ? "Бас тарту" : "Отклонить")
                        </a>
                    </div>
                </div>
            }
            else if (Model.IsPending && Model.IsInitiator)
            {
                <div class="alert alert-warning mb-2">
                    <i class="fas fa-clock"></i>
                    @(isKz ? "Шақыру жіберілді. Досыңыз қосылғанша күтіңіз." : "Приглашение отправлено. Ожидайте, пока друг присоединится.")
                </div>
            }

            @if (Model.IsClosed)
            {
                <div class="alert alert-secondary mb-2">
                    <i class="fas fa-lock"></i>
                    @(isKz ? "Бұл бөлме жабылды." : "Эта комната закрыта.")
                </div>
            }

            <div class="chat-messages room-chat-messages" id="chatMessages">
                @foreach (var message in Model.Messages)
                {
                    @if (message.IsSystemMessage)
                    {
                        <div class="chat-message system">
                            <div class="chat-system-bubble">
                                <i class="fas fa-info-circle"></i> @message.Text
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="chat-message @(message.IsOwn ? "own" : "other")">
                            @if (!message.IsOwn && !string.IsNullOrWhiteSpace(message.SenderAvatarUrl))
                            {
                                <img src="@message.SenderAvatarUrl" alt="@message.SenderName" class="chat-msg-avatar" />
                            }
                            <div class="chat-bubble">
                                @if (!message.IsOwn)
                                {
                                    <div class="chat-sender-name">@message.SenderName</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(message.Text)) { <p>@message.Text</p> }
                                @if (!string.IsNullOrWhiteSpace(message.ImageUrl))
                                {
                                    <img src="@message.ImageUrl" alt="img" class="chat-img-preview" />
                                }
                                <span class="chat-time">@message.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</span>
                            </div>
                        </div>
                    }
                }
            </div>

            @if (Model.IsActive)
            {
                <form class="chat-input" id="chatForm" asp-action="SendMessage" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="roomId" value="@Model.RoomId" />
                    <div class="chat-input-row">
                        <input class="form-control chat-text-input" name="text" id="chatTextInput"
                               placeholder="@(isKz ? "Хабарлама жазыңыз..." : "Напишите сообщение...")"
                               autocomplete="off" maxlength="2000" />
                        <label class="chat-img-btn" title="@(isKz ? "Сурет" : "Картинка")">
                            <i class="fas fa-image"></i>
                            <input type="file" name="image" id="chatImageInput" accept="image/*" class="d-none" />
                        </label>
                        <button class="btn-primary chat-send-btn" type="submit">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                    <div id="chatImagePreview" class="chat-img-preview-wrap d-none">
                        <img id="chatImagePreviewImg" src="#" alt="preview" />
                        <button type="button" id="chatImageClear" class="chat-img-clear"><i class="fas fa-times"></i></button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
.room-page {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 1.25rem;
    align-items: start;
    min-height: calc(100vh - 120px);
}
.room-player-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: sticky;
    top: 72px;
}
.room-video-wrap {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
    border: 1px solid rgba(139,92,246,0.25);
}
.room-video-iframe, .room-video-wrap video {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: 0;
}
.room-video-placeholder {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: var(--bg-card);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
}
.room-poster-fallback {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: blur(4px);
}
.room-no-video-msg {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: var(--muted);
}
.room-player-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    flex-wrap: wrap;
}
.room-movie-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}
.room-mini-poster {
    width: 36px;
    height: 52px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
}
.room-movie-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
}
.room-movie-link {
    font-size: 0.8rem;
    color: var(--accent-light);
}
.room-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
}
.room-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
}
.room-status-badge.active { background: rgba(16,185,129,0.15); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); }
.room-status-badge.active::before { content: ''; display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: #10b981; }
.room-status-badge.pending { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
.room-status-badge.closed { background: rgba(107,114,128,0.15); color: #9ca3af; border: 1px solid rgba(107,114,128,0.2); }

.room-chat-section { position: sticky; top: 72px; max-height: calc(100vh - 90px); display: flex; flex-direction: column; }
.room-chat-shell { display: flex; flex-direction: column; height: 100%; max-height: calc(100vh - 90px); overflow: hidden; }
.room-chat-messages { flex: 1; max-height: 450px; overflow-y: auto; padding: 0.5rem 0; }

.chat-system-bubble {
    display: inline-block;
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 999px;
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    color: var(--accent-light);
}
.chat-message.system { justify-content: center; margin: 0.5rem 0; }
.chat-sender-name { font-size: 0.75rem; color: var(--accent-light); margin-bottom: 0.2rem; font-weight: 600; }
.chat-msg-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 1px solid var(--accent); align-self: flex-end; margin-right: 0.4rem; }
.chat-img-preview { max-width: 180px; border-radius: var(--radius-sm); margin-top: 0.4rem; display: block; }
.chat-input-row { display: flex; gap: 0.5rem; align-items: center; }
.chat-text-input { flex: 1; }
.chat-img-btn { display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--bg-surface); color: var(--muted); cursor: pointer; flex-shrink: 0; transition: all 0.2s; }
.chat-img-btn:hover { border-color: var(--accent); color: var(--accent-light); }
.chat-send-btn { flex-shrink: 0; height: 38px; }
.chat-img-preview-wrap { position: relative; display: inline-block; margin-top: 0.5rem; }
.chat-img-preview-wrap img { max-height: 80px; border-radius: var(--radius-sm); }
.chat-img-clear { position: absolute; top: -6px; right: -6px; background: var(--danger); border: none; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.7rem; cursor: pointer; }
.friend-avatar-placeholder { width: 42px; height: 42px; border-radius: 50%; background: var(--bg-surface); border: 2px solid var(--accent); display: flex; align-items: center; justify-content: center; color: var(--muted); }
.dot-online { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: #10b981; margin-right: 4px; }
.alert-info { background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.3); color: #a5b4fc; border-radius: var(--radius-sm); padding: 0.75rem 1rem; }
.alert-warning { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); color: #fcd34d; border-radius: var(--radius-sm); padding: 0.75rem 1rem; }
.alert-secondary { background: rgba(75,85,99,0.2); border: 1px solid rgba(75,85,99,0.3); color: var(--muted); border-radius: var(--radius-sm); padding: 0.75rem 1rem; }
@@media (max-width: 900px) {
    .room-page { grid-template-columns: 1fr; }
    .room-player-section, .room-chat-section { position: static; }
    .room-chat-shell, .room-chat-section { max-height: none; }
    .room-chat-messages { max-height: 320px; }
}
</style>
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
(function() {
    const roomId = @Model.RoomId;
    const currentUserId = '@currentUserId';
    const chatMessages = document.getElementById('chatMessages');
    const chatForm = document.getElementById('chatForm');
    const chatTextInput = document.getElementById('chatTextInput');
    const chatImageInput = document.getElementById('chatImageInput');
    const chatImagePreview = document.getElementById('chatImagePreview');
    const chatImagePreviewImg = document.getElementById('chatImagePreviewImg');
    const chatImageClear = document.getElementById('chatImageClear');

    // Auto scroll to bottom
    function scrollToBottom() {
        if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    scrollToBottom();

    // Image preview
    if (chatImageInput) {
        chatImageInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    chatImagePreviewImg.src = e.target.result;
                    chatImagePreview.classList.remove('d-none');
                };
                reader.readAsDataURL(this.files[0]);
            }
        });
    }
    if (chatImageClear) {
        chatImageClear.addEventListener('click', function() {
            chatImageInput.value = '';
            chatImagePreview.classList.add('d-none');
            chatImagePreviewImg.src = '#';
        });
    }

    // SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/discussionRoom')
        .withAutomaticReconnect()
        .build();

    connection.on('ReceiveMessage', function(msg) {
        if (!chatMessages) return;
        const isOwn = msg.senderId === currentUserId && !msg.isSystemMessage;
        const timeStr = msg.createdAtUtc
            ? new Date(msg.createdAtUtc).toLocaleString('default', {day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'})
            : (msg.createdAt || '');
        const div = document.createElement('div');
        if (msg.isSystemMessage) {
            div.className = 'chat-message system';
            div.innerHTML = `<div class="chat-system-bubble"><i class="fas fa-info-circle"></i> ${escHtml(msg.text || '')}</div>`;
        } else {
            div.className = 'chat-message ' + (isOwn ? 'own' : 'other');
            const avatarHtml = (!isOwn && msg.senderAvatar)
                ? `<img src="${escHtml(msg.senderAvatar)}" class="chat-msg-avatar" alt="" />`
                : '';
            const nameHtml = !isOwn ? `<div class="chat-sender-name">${escHtml(msg.senderName || '')}</div>` : '';
            const textHtml = msg.text ? `<p>${escHtml(msg.text)}</p>` : '';
            const imgHtml = msg.imageUrl ? `<img src="${escHtml(msg.imageUrl)}" class="chat-img-preview" />` : '';
            div.innerHTML = `${avatarHtml}<div class="chat-bubble">${nameHtml}${textHtml}${imgHtml}<span class="chat-time">${escHtml(timeStr)}</span></div>`;
        }
        chatMessages.appendChild(div);
        scrollToBottom();
    });

    connection.on('RoomClosed', function() {
        const div = document.createElement('div');
        div.className = 'chat-message system';
        div.innerHTML = `<div class="chat-system-bubble"><i class="fas fa-lock"></i> @(isKz ? "Бөлме жабылды" : "Комната закрыта")</div>`;
        if (chatMessages) { chatMessages.appendChild(div); scrollToBottom(); }
        if (chatForm) chatForm.style.display = 'none';
        setTimeout(() => window.location.reload(), 1500);
    });

    connection.start()
        .then(() => connection.invoke('JoinRoom', roomId))
        .catch(err => console.warn('SignalR error:', err));

    // On form submit, use SignalR for text-only, fallback to form POST for images
    if (chatForm) {
        chatForm.addEventListener('submit', async function(e) {
            const hasImage = chatImageInput && chatImageInput.files && chatImageInput.files.length > 0;
            if (!hasImage) {
                e.preventDefault();
                const text = chatTextInput ? chatTextInput.value.trim() : '';
                if (!text) return;
                try {
                    await connection.invoke('SendMessage', roomId, text, null);
                    if (chatTextInput) chatTextInput.value = '';
                } catch (err) {
                    console.warn('SignalR SendMessage failed, posting form', err);
                    chatForm.submit();
                }
            }
            // If has image, let form POST handle it normally
        });
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
})();
</script>
}

