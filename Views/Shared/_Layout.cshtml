@using System.Globalization
@{
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isKz = culture == "kk" || culture == "kz";
}
<!DOCTYPE html>
<html lang="@(isKz ? "kk" : "ru")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Watchly</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Google Fonts - красивые шрифты -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
            * {
                font-family: 'Inter', 'Poppins', sans-serif;
            }
        
            body {
                background: #000000;
                color: #ffffff;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }
        
            main {
                flex: 1;
                padding-top: 2rem;
            }
        
            /* NAVBAR STICKY НА МОБИЛЬНЫХ */
            @@media (max-width: 992px) {
                .navbar {
                    position: sticky;
                    top: 0;
                    z-index: 1000;
                }
            }
        
            /* Footer стили */
            footer {
                background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
                border-top: 1px solid rgba(139, 92, 246, 0.3);
                padding: 3rem 0 1rem;
                margin-top: auto;
            }
        
                footer h5 {
                    font-weight: 700;
                    font-size: 1.25rem;
                    margin-bottom: 1rem;
                    color: #8b5cf6;
                }
        
                footer a {
                    color: #d1d5db;
                    text-decoration: none;
                    font-weight: 500;
                    transition: all 0.3s ease;
                    display: inline-block;
                }
        
                    footer a:hover {
                        color: #8b5cf6;
                        transform: translateX(5px);
                    }
        
                footer ul li {
                    margin-bottom: 0.75rem;
                }
        
                footer .social-icons a {
                    font-size: 1.5rem;
                    display: inline-block;
                }
        
                    footer .social-icons a:hover {
                        transform: scale(1.3) rotate(10deg);
                    }
        
                footer .text-muted {
                    color: #9ca3af !important;
                    font-weight: 500;
                }
        
            .gradient-text {
                background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
                font-weight: 700;
            }
    </style>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- НАВИГАЦИЯ -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top" style="border-bottom: 1px solid rgba(139, 92, 246, 0.2);">
        <div class="container-lg">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="fas fa-film" style="color: #8b5cf6;"></i> <strong>Watchly</strong>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Cinema")">
                            <i class="fas fa-th"></i> @(isKz ? "Каталог" : "Каталог")
                        </a>
                    </li>
                    
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Watchlist", "Cinema")">
                                <i class="fas fa-heart"></i> @(isKz ? "Таңдаулылар" : "Избранное")
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("ViewHistory", "Cinema")">
                                <i class="fas fa-history"></i> @(isKz ? "Тарих" : "История")
                            </a>
                        </li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Dashboard", "Admin")">
                                    <i class="fas fa-cog"></i> @(isKz ? "Әкімші" : "Админ")
                                </a>
                            </li>
                        }
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end bg-dark" aria-labelledby="userMenu">
                                <li><a class="dropdown-item text-light" href="@Url.Action("Index", "Profile")">@(isKz ? "Профиль" : "Профиль")</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" action="@Url.Action("Logout", "Account")">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">@(isKz ? "Шығу" : "Выход")</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">
                                <i class="fas fa-sign-in-alt"></i> @(isKz ? "Кіру" : "Вход")
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Register", "Account")">
                                <i class="fas fa-user-plus"></i> @(isKz ? "Тіркелу" : "Регистрация")
                            </a>
                        </li>
                    }
                    <li class="nav-item d-flex align-items-center">
                        <form method="post" action="@Url.Action("SetLanguage", "Home")" class="d-flex gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button class="btn btn-sm lang-btn @(isKz ? string.Empty : "active")" name="lang" value="ru" type="submit">RU</button>
                            <button class="btn btn-sm lang-btn @(isKz ? "active" : string.Empty)" name="lang" value="kz" type="submit">KZ</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <main class="flex-grow-1">
        <div class="container-lg">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            @RenderBody()
        </div>
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container-lg">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="gradient-text mb-3">
                        <i class="fas fa-film"></i> Watchly
                    </h5>
                    <p class="text-muted" style="font-weight: 500;">@(isKz ? "Қосымшамызбен кино әлемін ашыңыз. Іздеңіз, көріңіз және сүйікті фильмдеріңізді сақтаңыз." : "Откройте мир кинематографии с нашим приложением. Ищите, смотрите и сохраняйте ваши любимые фильмы.")</p>
                </div>
                
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-link"></i> @(isKz ? "Жылдам сілтемелер" : "Быстрые ссылки")</h5>
                    <ul class="list-unstyled">
                        <li><a href="@Url.Action("Index", "Home")"><i class="fas fa-chevron-right"></i> @(isKz ? "Басты бет" : "Главная")</a></li>
                        <li><a href="@Url.Action("Index", "Cinema")"><i class="fas fa-chevron-right"></i> @(isKz ? "Фильмдер каталогы" : "Каталог фильмов")</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> @(isKz ? "Жоба туралы" : "О проекте")</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> @(isKz ? "Байланыс" : "Контакты")</a></li>
                    </ul>
                </div>
                
                <div class="col-md-4 mb-4">
                    <h5><i class="fas fa-share-alt"></i> @(isKz ? "Әлеуметтік желілер" : "Социальные сети")</h5>
                    <div class="social-icons">
                        <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" title="Facebook"><i class="fab fa-facebook"></i></a>
                        <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            
            <hr class="border-secondary opacity-25" />
            
            <div class="text-center">
                <p class="text-muted mb-1">
                    <i class="fas fa-copyright"></i> @DateTime.Now.Year <strong>Watchly</strong> — @(isKz ? "Сіздің жеке кинотеатрыңыз" : "Ваш личный кинотеатр")
                </p>

            </div>
        </div>
    </footer>

    <!-- jQuery (ВАЖНО! ДОЛЖНА БЫТЬ ПЕРВОЙ) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
